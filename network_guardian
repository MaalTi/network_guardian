#!/bin/bash
# network_guardian.sh - Home network watchdog (nmap scan, telemetry, desktop notifications)
# Usage: network_guardian.sh [options] | network_guardian.sh --daemon [options]

set -o pipefail

VERSION="1.0.0"

#####################################################
# COLORS
#####################################################
C_CYAN="\033[1;36m"
C_GREEN="\033[1;32m"
C_RED="\033[1;31m"
C_YELLOW="\033[1;33m"
C_BLUE="\033[1;34m"
C_RESET="\033[0m"
C_BOLD="\033[1m"

#####################################################
# LOGGING AND UTILITY FUNCTIONS
#####################################################
log()    { [[ "$QUIET" == true ]] || echo -e "${C_CYAN}$1${C_RESET}"; }
success() { [[ "$QUIET" == true ]] || echo -e "${C_GREEN}$1${C_RESET}"; }
warn()   { [[ "$QUIET" == true ]] || echo -e "${C_YELLOW}$1${C_RESET}"; }
err()    { echo -e "${C_RED}$1${C_RESET}" >&2; exit 1; }
info()   { [[ "$QUIET" == true ]] || echo -e "${C_BLUE}$1${C_RESET}"; }
need()   { command -v "$1" >/dev/null 2>&1 || err "❌ '$1' is required. Install it first."; }

log_to_file() {
    if [[ -n "$MAIN_LOG" ]]; then
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$MAIN_LOG" 2>/dev/null || true
    fi
}

send_notification() {
    local title="$1"
    local message="$2"
    if command -v fyi &>/dev/null; then
        fyi "$title" "$message" 2>/dev/null &
        return 0
    fi
    if command -v osascript &>/dev/null; then
        osascript -e "display notification \"$message\" with title \"$title\"" 2>/dev/null &
        return 0
    fi
    return 1
}

# Extract a sorted list of hosts (IP or "hostname (IP)") from an nmap output file
extract_hosts() {
    local f="$1"
    [[ ! -f "$f" ]] && return 0
    grep "Nmap scan report for " "$f" 2>/dev/null | sed 's/.*Nmap scan report for //' | sort -u
}

# Extract IPs only (from "hostname (IP)" or "IP") for stable comparison
extract_ips() {
    local f="$1"
    [[ ! -f "$f" ]] && return 0
    grep "Nmap scan report for " "$f" 2>/dev/null | sed 's/.*Nmap scan report for //' | while read -r line; do
        if [[ "$line" =~ \(([0-9][0-9.]*)\) ]]; then
            echo "${BASH_REMATCH[1]}"
        else
            echo "$line"
        fi
    done | sort -u
}

# Convert IPv4 to 32-bit integer
ip_to_int() {
    local a b c d
    IFS=. read -r a b c d <<< "$1"
    [[ -z "$b" ]] && { echo 0; return 1; }
    echo $(( (a << 24) + (b << 16) + (c << 8) + d )) 2>/dev/null || echo 0
}

# Return 0 if the IP should be ignored (allowlist)
is_ignored() {
    local ip="$1"
    local x line base prefix ip_int
    for x in "${IGNORE_IPS[@]:-}"; do
        [[ -n "$x" && "$ip" == "$x" ]] && return 0
    done
    if [[ -f "${IGNORE_FILE:-}" ]]; then
        ip_int=$(ip_to_int "$ip")
        while read -r line; do
            [[ -z "$line" || "$line" =~ ^# ]] && continue
            if [[ "$line" == *"/"* ]]; then
                base="${line%/*}"
                prefix="${line##*/}"
                local base_int mask
                base_int=$(ip_to_int "$base")
                if [[ "$prefix" -eq 0 ]]; then
                    mask=0
                else
                    mask=$(( 0xFFFFFFFF << (32 - prefix) & 0xFFFFFFFF ))
                fi
                if (((ip_int & mask) == (base_int & mask))); then
                    return 0
                fi
            else
                [[ "$ip" == "$line" ]] && return 0
            fi
        done < "$IGNORE_FILE"
    fi
    return 1
}

load_ignore_list() {
    IGNORE_IPS=("${IGNORE_IPS[@]:-}")
    if [[ -n "${IGNORE_FILE:-}" ]] && [[ -f "$IGNORE_FILE" ]]; then
        while read -r line; do
            [[ -z "$line" || "$line" =~ ^# ]] && continue
            if [[ "$line" != *"/"* ]]; then
                IGNORE_IPS+=("$line")
            fi
        done < "$IGNORE_FILE"
    fi
}

# Save current scan to history and keep at most HISTORY_MAX files
save_to_history() {
    [[ "$HISTORY_MAX" -le 0 ]] && return 0
    mkdir -p "$HISTORY_DIR"
    local stamp
    stamp=$(date +%Y%m%d_%H%M%S)
    local histfile="$HISTORY_DIR/scan_${stamp}.txt"
    if [[ "${COMPARE_BY_IP_ONLY}" == true ]]; then
        extract_ips "$NEW_LOG" > "$histfile"
    else
        extract_hosts "$NEW_LOG" > "$histfile"
    fi
    local count
    count=$(find "$HISTORY_DIR" -maxdepth 1 -name 'scan_*.txt' 2>/dev/null | wc -l)
    while [[ "$count" -gt "$HISTORY_MAX" ]]; do
        local oldest
        oldest=$(find "$HISTORY_DIR" -maxdepth 1 -name 'scan_*.txt' -printf '%T@ %p\n' 2>/dev/null | sort -n | head -1 | { read -r _ p; echo "$p"; })
        [[ -n "$oldest" ]] && rm -f "$oldest"
        count=$((count - 1))
    done
}

# List history files (oldest first), at most HISTORY_MAX
get_history_files_oldest_first() {
    find "$HISTORY_DIR" -maxdepth 1 -name 'scan_*.txt' -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -n "${HISTORY_MAX}" | while read -r _ path; do echo "$path"; done
}

# From history, compute ADDED and REMOVED with debounce (global arrays)
compute_added_removed_from_history() {
    ADDED=()
    REMOVED=()
    local files
    mapfile -t files < <(get_history_files_oldest_first)
    local need=$((MIN_PRESENCE_SCANS > MIN_ABSENCE_SCANS ? MIN_PRESENCE_SCANS : MIN_ABSENCE_SCANS))
    need=$((need + 1))
    if [[ ${#files[@]} -lt $need ]]; then
        return
    fi
    local newest="${files[${#files[@]}-1]}"
    local oldest="${files[0]}"
    local baseline
    baseline=$(cat "$oldest" 2>/dev/null)
    local current
    current=$(cat "$newest" 2>/dev/null)
    local ip
    for ip in $current; do
        is_ignored "$ip" && continue
        if ! echo "$baseline" | grep -qxF "$ip"; then
            local count=0 i
            for ((i=${#files[@]}-1; i>=0; i--)); do
                grep -qxF "$ip" "${files[$i]}" 2>/dev/null || break
                count=$((count + 1))
            done
            [[ $count -ge "$MIN_PRESENCE_SCANS" ]] && ADDED+=("$ip")
        fi
    done
    for ip in $baseline; do
        is_ignored "$ip" && continue
        if ! echo "$current" | grep -qxF "$ip"; then
            local count=0 i
            for ((i=${#files[@]}-1; i>=0; i--)); do
                grep -qxF "$ip" "${files[$i]}" 2>/dev/null && break
                count=$((count + 1))
            done
            [[ $count -ge "$MIN_ABSENCE_SCANS" ]] && REMOVED+=("$ip")
        fi
    done
}

# Read pending alert file (added, removed, count)
read_pending_alert() {
    PENDING_ADDED=()
    PENDING_REMOVED=()
    PENDING_COUNT=0
    [[ ! -f "$PENDING_ALERT_FILE" ]] && return
    local line t x
    while read -r line; do
        if [[ "$line" = added=* ]]; then
            IFS=',' read -ra t <<< "${line#added=}"
            for x in "${t[@]}"; do [[ -n "$x" ]] && PENDING_ADDED+=("$x"); done
        elif [[ "$line" = removed=* ]]; then
            IFS=',' read -ra t <<< "${line#removed=}"
            for x in "${t[@]}"; do [[ -n "$x" ]] && PENDING_REMOVED+=("$x"); done
        elif [[ "$line" = count=* ]]; then
            PENDING_COUNT="${line#count=}"
        fi
    done < "$PENDING_ALERT_FILE"
}

# Write pending alert file
write_pending_alert() {
    local add_str rem_str
    add_str=$(IFS=','; echo "${ADDED[*]:-}")
    rem_str=$(IFS=','; echo "${REMOVED[*]:-}")
    { echo "added=$add_str"; echo "removed=$rem_str"; echo "count=$PENDING_COUNT"; } > "$PENDING_ALERT_FILE"
}

# Compare ADDED/REMOVED arrays with PENDING (same set)
pending_equals_current() {
    local a b
    a=$(printf '%s\n' "${ADDED[@]:-}" | sort -u)
    b=$(printf '%s\n' "${PENDING_ADDED[@]:-}" | sort -u)
    [[ "$a" != "$b" ]] && return 1
    a=$(printf '%s\n' "${REMOVED[@]:-}" | sort -u)
    b=$(printf '%s\n' "${PENDING_REMOVED[@]:-}" | sort -u)
    [[ "$a" == "$b" ]]
}

# Filter ADDED and REMOVED by ignore list (in place)
filter_ignored() {
    local i tmp=()
    for i in "${ADDED[@]:-}"; do
        is_ignored "$i" || tmp+=("$i")
    done
    ADDED=("${tmp[@]:-}")
    tmp=()
    for i in "${REMOVED[@]:-}"; do
        is_ignored "$i" || tmp+=("$i")
    done
    REMOVED=("${tmp[@]:-}")
}

# Run one scan and comparison (legacy or history + debounce + confirmation)
run_one_scan() {
    if [[ -n "$XML_LOG" ]]; then
        nmap -sn -T4 --max-retries 1 "$NETWORK" -oN "$NEW_LOG" -oX "$XML_LOG" || err "Échec du scan nmap"
    else
        nmap -sn -T4 --max-retries 1 "$NETWORK" -oN "$NEW_LOG" || err "Échec du scan nmap"
    fi

    CHANGED=false
    ADDED=()
    REMOVED=()

    if [[ "$HISTORY_MAX" -gt 0 ]]; then
        save_to_history
        compute_added_removed_from_history
        if [[ ${#ADDED[@]} -gt 0 ]] || [[ ${#REMOVED[@]} -gt 0 ]]; then
            CHANGED=true
        fi
        if [[ "$CHANGED" == true ]]; then
            read_pending_alert
            if pending_equals_current; then
                PENDING_COUNT=$((PENDING_COUNT + 1))
            else
                PENDING_ADDED=("${ADDED[@]}")
                PENDING_REMOVED=("${REMOVED[@]}")
                PENDING_COUNT=1
            fi
            write_pending_alert
            if [[ "$PENDING_COUNT" -ge "$CONFIRM_SCANS" ]]; then
                do_alert
                rm -f "$PENDING_ALERT_FILE"
            fi
        else
            rm -f "$PENDING_ALERT_FILE"
            success "Aucun changement détecté."
        fi
        log_to_file "Scan terminé, historique mis à jour"
    else
        if [[ -f "$OLD_LOG" ]]; then
            local old_list new_list
            if [[ "${COMPARE_BY_IP_ONLY}" == true ]]; then
                old_list=$(mktemp)
                new_list=$(mktemp)
                extract_ips "$OLD_LOG" > "$old_list"
                extract_ips "$NEW_LOG" > "$new_list"
            else
                old_list=$(mktemp)
                new_list=$(mktemp)
                extract_hosts "$OLD_LOG" > "$old_list"
                extract_hosts "$NEW_LOG" > "$new_list"
            fi
            mapfile -t ADDED < <(comm -13 "$old_list" "$new_list")
            mapfile -t REMOVED < <(comm -23 "$old_list" "$new_list")
            rm -f "$old_list" "$new_list"
            filter_ignored
            if [[ ${#ADDED[@]} -gt 0 ]] || [[ ${#REMOVED[@]} -gt 0 ]]; then
                CHANGED=true
            fi
        else
            info "Premier scan : pas de baseline pour comparaison."
        fi
        if [[ "$CHANGED" == true ]]; then
            do_alert
        else
            success "Aucun changement détecté."
        fi
        cp "$NEW_LOG" "$OLD_LOG"
    fi
}

do_alert() {
    log_to_file "Changement détecté : +${#ADDED[@]} -${#REMOVED[@]}"
    echo "" >> "$ALERTS_LOG"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Changement réseau ($NETWORK)" >> "$ALERTS_LOG"
    [[ ${#ADDED[@]} -gt 0 ]] && printf '  Ajoutés: %s\n' "${ADDED[*]}" >> "$ALERTS_LOG"
    [[ ${#REMOVED[@]} -gt 0 ]] && printf '  Retirés: %s\n' "${REMOVED[*]}" >> "$ALERTS_LOG"
    local MSG=""
    [[ ${#ADDED[@]} -gt 0 ]] && MSG="${#ADDED[@]} ajouté(s)"
    [[ ${#REMOVED[@]} -gt 0 ]] && MSG="${MSG:+$MSG, }${#REMOVED[@]} retiré(s)"
    send_notification "Network Guardian" "${MSG:-Changement détecté}. Voir $ALERTS_LOG"
    warn "Changement détecté : $MSG"
}

#####################################################
# DEFAULT OPTIONS
#####################################################
NETWORK="${NETWORK:-192.168.1.0/24}"
LOG_DIR="${LOG_DIR:-$HOME/.nmap_logs}"
QUIET="${QUIET:-false}"
HELP=false
OPEN_ZENMAP=false
DAEMON=false
INSTALL_SERVICE=false
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/network_guardian/config"

# Telemetry / anti false-positives (disabled = legacy behaviour)
HISTORY_MAX="${HISTORY_MAX:-0}"
INTERVAL="${INTERVAL:-}"
CONFIRM_SCANS="${CONFIRM_SCANS:-2}"
MIN_PRESENCE_SCANS="${MIN_PRESENCE_SCANS:-2}"
MIN_ABSENCE_SCANS="${MIN_ABSENCE_SCANS:-2}"
COMPARE_BY_IP_ONLY="${COMPARE_BY_IP_ONLY:-true}"
IGNORE_IPS=()
IGNORE_FILE="${IGNORE_FILE:-}"

NEW_LOG="$LOG_DIR/current_scan.txt"
OLD_LOG="$LOG_DIR/previous_scan.txt"
ALERTS_LOG="$LOG_DIR/alerts.log"
MAIN_LOG="$LOG_DIR/network_guardian.log"
XML_LOG="$LOG_DIR/current_scan.xml"
HISTORY_DIR="$LOG_DIR/history"
PENDING_ALERT_FILE="$LOG_DIR/.pending_alert"

# Load config file (if present)
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
    NEW_LOG="$LOG_DIR/current_scan.txt"
    OLD_LOG="$LOG_DIR/previous_scan.txt"
    ALERTS_LOG="$LOG_DIR/alerts.log"
    MAIN_LOG="$LOG_DIR/network_guardian.log"
    XML_LOG="$LOG_DIR/current_scan.xml"
    HISTORY_DIR="$LOG_DIR/history"
    PENDING_ALERT_FILE="$LOG_DIR/.pending_alert"
fi

#####################################################
# CLI OPTIONS
#####################################################
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            HELP=true
            shift
            ;;
        --quiet|-q)
            QUIET=true
            shift
            ;;
        --network=*)
            NETWORK="${1#*=}"
            shift
            ;;
        --config=*)
            CONFIG_FILE="${1#*=}"
            shift
            ;;
        --zenmap)
            OPEN_ZENMAP=true
            shift
            ;;
        --daemon|-d)
            DAEMON=true
            shift
            ;;
        --interval=*)
            INTERVAL="${1#*=}"
            shift
            ;;
        --history-max=*)
            HISTORY_MAX="${1#*=}"
            shift
            ;;
        --install-service)
            INSTALL_SERVICE=true
            shift
            ;;
        -*)
            err "Unknown option: $1"
            ;;
        *)
            err "Unexpected argument: $1"
            ;;
    esac
done

if [[ "$HELP" == true ]]; then
    echo -e "${C_BOLD}network_guardian${C_RESET} v${VERSION} - Network watchdog (nmap scan, telemetry, desktop notifications)"
    echo ""
    echo -e "${C_BOLD}USAGE:${C_RESET}"
    echo "    $(basename "$0") [options]       # one-shot (or cron)"
    echo "    $(basename "$0") --daemon [options]  # real-time loop"
    echo ""
    echo -e "${C_BOLD}OPTIONS:${C_RESET}"
    echo "    --network=CIDR    Network to scan (default: 192.168.1.0/24)"
    echo "    --config=FILE     Config file to load"
    echo "    --zenmap          Open Zenmap with target after scan"
    echo "    --daemon, -d      Daemon mode (loop with --interval)"
    echo "    --interval=SECS   Interval between scans in seconds (daemon mode)"
    echo "    --history-max=N   Number of scans in history (0 = legacy, default: 0)"
    echo "    --install-service Create ~/.config/systemd/user/network-guardian.service"
    echo "    --quiet, -q       Reduce messages on standard output"
    echo "    --help, -h        Show this help"
    echo ""
    echo -e "${C_BOLD}CONFIG:${C_RESET} ${CONFIG_FILE}"
    echo "    NETWORK, LOG_DIR, QUIET, INTERVAL, HISTORY_MAX, CONFIRM_SCANS,"
    echo "    MIN_PRESENCE_SCANS, MIN_ABSENCE_SCANS, COMPARE_BY_IP_ONLY, IGNORE_IPS, IGNORE_FILE"
    echo ""
    echo -e "${C_BOLD}SYSTEMD (user service):${C_RESET}"
    echo "    systemctl --user start network-guardian   # Start"
    echo "    systemctl --user restart network-guardian  # Restart"
    echo "    systemctl --user status network-guardian  # Status"
    echo "    systemctl --user enable network-guardian  # Start at session"
    echo "    systemctl --user disable network-guardian # Do not start at session"
    echo "    Unit: ~/.config/systemd/user/network-guardian.service"
    echo ""
    exit 0
fi

if [[ "$INSTALL_SERVICE" == true ]]; then
    SCRIPT_PATH="$(realpath "$0" 2>/dev/null)" || SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null)" || SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    SERVICE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
    SERVICE_FILE="$SERVICE_DIR/network-guardian.service"
    mkdir -p "$SERVICE_DIR"
    cat > "$SERVICE_FILE" << EOF
[Unit]
Description=Network Guardian - network watchdog (nmap scan, telemetry)
Documentation=file://${SCRIPT_PATH}
PartOf=graphical-session.target
After=graphical-session.target network-online.target
Wants=network-online.target

[Service]
Type=simple
# Interval between scans (seconds). Overridden by ~/.config/network_guardian/config
Environment=INTERVAL=120
ExecStart=${SCRIPT_PATH} --daemon --quiet
Restart=on-failure
RestartSec=60

[Install]
WantedBy=graphical-session.target
EOF
    success "Unit created: $SERVICE_FILE"
    info "Reload systemd then start: systemctl --user daemon-reload && systemctl --user start network-guardian"
    if command -v systemctl &>/dev/null; then
        systemctl --user daemon-reload 2>/dev/null && info "Systemd daemon reloaded."
    fi
    exit 0
fi

# Dependencies
need nmap

# Create log directory
mkdir -p "$LOG_DIR"
[[ "$HISTORY_MAX" -gt 0 ]] && mkdir -p "$HISTORY_DIR"
load_ignore_list

if [[ "$DAEMON" == true ]]; then
    if [[ -z "$INTERVAL" ]] || [[ "$INTERVAL" -le 0 ]]; then
        err "Daemon mode requires: --interval=SECS (e.g. --interval=120)"
    fi
    log "Mode daemon : scan toutes les ${INTERVAL}s (Ctrl+C pour arrêter)"
    log_to_file "Démarrage daemon $NETWORK (interval=${INTERVAL}s)"
    while true; do
        run_one_scan
        sleep "$INTERVAL"
    done
else
    log_to_file "Démarrage scan $NETWORK"
    run_one_scan
fi

# Option --zenmap: open Zenmap with target or last XML result
if [[ "$OPEN_ZENMAP" == true ]]; then
    if command -v zenmap &>/dev/null; then
        if [[ -f "$XML_LOG" ]]; then
            zenmap -f "$XML_LOG" 2>/dev/null &
        else
            zenmap -t "$NETWORK" 2>/dev/null &
        fi
    else
        warn "Zenmap n'est pas installé. Installez le paquet zenmap pour utiliser --zenmap."
    fi
fi
